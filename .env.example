# Copy to .env and fill in keys you have. Everything is optional;
# sources with missing keys are skipped at runtime with a warning.

# --- Equities / bars ---
ALPHA_VANTAGE_KEY=
TWELVE_DATA_KEY=
FINNHUB_KEY=
POLYGON_KEY=
ALPACA_KEY=
ALPACA_SECRET=
ALPACA_PAPER=true

# --- Macro ---
FRED_KEY=
BLS_KEY=
EIA_KEY=

# --- News / sentiment ---
NEWSAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=mlbt:v0.1 (by u/your_username)

# --- Storage ---
MLBT_DATA_DIR=./data
MLBT_DEFAULT_BAR=5min
MLBT_TZ=UTC
